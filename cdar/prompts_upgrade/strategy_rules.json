{
  "strategies": ["direct", "decomposed"],
  "rules": {
    "direct": {
      "description": "Single-step reasoning",
      "conditions": ["simple", "single type", "no complex relationships"],
      "use_cases": ["yes_no", "simple description", "basic attribute"]
    },
    "decomposed": {
      "description": "Multi-step reasoning",
      "conditions": ["moderate/complex", "multiple types", "synthesis required"],
      "use_cases": ["counting", "multiple_choice", "spatial", "temporal", "causal"]
    }
  },
  "auto_subtask_mapping": {
    "multiple_choice": [
      {"type": "visual_detection", "depends_on": [], "description": "detect objects and regions", "output": "entities and attributes"},
      {"type": "synthesis", "depends_on": ["visual_detection"], "description": "map to choice", "output": "A/B/C/D"}
    ],
    "counting": [
      {"type": "visual_detection", "depends_on": [], "description": "detect targets", "output": "list of targets"},
      {"type": "counting", "depends_on": ["visual_detection"], "description": "count objects", "output": "count number"}
    ],
    "spatial_relational": [
      {"type": "spatial_analysis", "depends_on": [], "description": "analyze spatial relations", "output": "spatial facts"}
    ],
    "temporal": [
      {"type": "temporal_analysis", "depends_on": [], "description": "analyze time sequence", "output": "temporal insights"}
    ],
    "numerical_reasoning": [
      {"type": "numerical_analysis", "depends_on": [], "description": "perform calculations", "output": "numerical result"}
    ],
    "causal_logical": [
      {"type": "causal_analysis", "depends_on": [], "description": "identify cause-effect", "output": "causal relationships"}
    ],
    "emotion_recognition": [
      {"type": "emotion_analysis", "depends_on": [], "description": "recognize emotions", "output": "emotional assessment"}
    ],
    "object_identification": [
      {"type": "visual_detection", "depends_on": [], "description": "identify entities", "output": "list of entities"},
      {"type": "attribute_analysis", "depends_on": ["visual_detection"], "description": "analyze attributes", "output": "detailed attributes"},
      {"type": "synthesis", "depends_on": ["attribute_analysis"], "description": "provide identification", "output": "entity type"}
    ],
    "attribute": [
      {"type": "visual_detection", "depends_on": [], "description": "locate object", "output": "object location"},
      {"type": "attribute_analysis", "depends_on": ["visual_detection"], "description": "examine attribute", "output": "attribute value"},
      {"type": "synthesis", "depends_on": ["attribute_analysis"], "description": "provide value", "output": "attribute answer"}
    ],
    "action": [
      {"type": "visual_detection", "depends_on": [], "description": "identify actors and objects", "output": "actors and objects"},
      {"type": "temporal_analysis", "depends_on": ["visual_detection"], "description": "analyze action", "output": "action description"}
    ],
    "comparative": [
      {"type": "visual_detection", "depends_on": [], "description": "identify comparison targets", "output": "comparison objects"},
      {"type": "comparison", "depends_on": ["visual_detection"], "description": "compare systematically", "output": "comparison results"},
      {"type": "synthesis", "depends_on": ["comparison"], "description": "conclude", "output": "comparative answer"}
    ]
  }
}
