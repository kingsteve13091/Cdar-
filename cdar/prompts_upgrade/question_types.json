{
  "version": "2.2-Scientific-Taxonomy",
  "metadata": {
    "framework": "CDAR",
    "description": "Defines the cognitive mapping between question types and algorithmic weighting profiles."
  },

  "type_specifications": {
    "counting": {
      "epistemic_focus": "Object Enumeration",
      "visual_sensitivity": "high",
      "required_anchors": ["target_instance", "background_context"],
      "sub_types": ["exact", "estimate", "density_based"]
    },
    "spatial_relational": {
      "epistemic_focus": "Topological Mapping",
      "visual_sensitivity": "medium",
      "required_anchors": ["subject_anchor", "reference_anchor"],
      "sub_types": ["topological", "geometric", "relative_depth"]
    },
    "causal_logical": {
      "epistemic_focus": "Abductive Inference",
      "visual_sensitivity": "low",
      "required_anchors": ["active_agent", "environmental_affordance"],
      "sub_types": ["physical_cause", "logical_inference", "counterfactual"]
    },
    "attribute": {
      "epistemic_focus": "Property Extraction",
      "visual_sensitivity": "high",
      "required_anchors": ["target_surface"],
      "sub_types": ["chromatic", "morphological", "material", "state"]
    },
    "temporal": {
      "epistemic_focus": "Sequential Estimation",
      "visual_sensitivity": "medium",
      "required_anchors": ["motion_vector", "state_boundary"],
      "sub_types": ["sequence", "prediction", "duration"]
    },
    "numerical_reasoning": {
      "epistemic_focus": "Quantitative Synthesis",
      "visual_sensitivity": "low",
      "required_anchors": ["quantitative_source"],
      "sub_types": ["arithmetic", "comparison", "ratio"]
    }
  },

  "complexity_priority_matrix": {
    "high_complexity_threshold": ["causal_logical", "temporal", "numerical_reasoning", "counting"],
    "medium_complexity_threshold": ["spatial_relational", "comparative", "multiple_choice"],
    "low_complexity_threshold": ["attribute", "object_identification", "description", "yes_no"]
  },

  "audit_constraints": {
    "mandatory_decomposition": ["counting", "causal_logical", "temporal", "numerical_reasoning"],
    "force_image_reaccess_depth": 3,
    "mismatch_tolerance": 1
  }
}