{
  "version": "1.0",
  "description": "System-wide hyperparameters and configuration (Configuration-Driven Framework)",
  
  "calibration": {
    "objective_confidence_threshold": 0.6,
    "subjective_confidence_threshold": 0.7,
    "default_confidence": 0.5,
    "fallback_confidence": 0.7,
    "epsilon": 1e-6,
    "precision_decimal_places": 3,
    "entropy_penalty_coefficient": 0.5
  },
  
  "cisc_synthesis": {
    "sampling_k": 5,
    "confidence_temperature": 0.5,
    "api_temperature": 0.7,
    "base_seed": 42,
    "default_confidence": 0.5,
    "max_subtask_results": 10,
    "fallback_max_subtask_results": 10,
    "adaptive_k_enabled": true,
    "k_green_channel": 1,
    "k_high_confidence_threshold": 0.8,
    "k_high_confidence": 3,
    "k_default": 5
  },
  
  "logical_consistency": {
    "severe_conflict_penalty": 0.5,
    "moderate_conflict_penalty": 0.3,
    "minor_conflict_penalty": 0.1,
    "severe_diff_threshold": 0.5,
    "moderate_diff_threshold": 0.2
  },
  
  "visual_risk": {
    "risk_penalty_per_item": 0.1,
    "max_risk_penalty": 0.3,
    "min_confidence_after_penalty": 0.1,
    "no_risk_placeholder": "none",
    "green_channel_confidence_boost": 0.05,
    "green_channel_strategy_preference": "direct",
    "critical_risks": [
      "perspective_ambiguity",
      "target_too_small",
      "severe_occlusion",
      "semantic_trap"
    ]
  },
  
  "image_processing": {
    "max_size_mb": 25.0,
    "thumbnail": {
      "max_width": 512,
      "max_height": 512,
      "quality": 75
    },
    "compression": {
      "target_size_ratio": 0.95,
      "initial_quality": 90,
      "min_quality": 60,
      "quality_step": 5,
      "max_attempts": 8,
      "megapixel_threshold": 1600000,
      "min_scale": 0.5,
      "max_scale": 0.95,
      "min_width": 640,
      "min_height": 480
    },
    "supported_formats": ["JPEG", "JPG", "PNG"],
    "output_format": "JPEG",
    "color_mode": "RGB"
  },
  
  "text_processing": {
    "log_preview_length": 500,
    "subtask_result_preview": 500,
    "fallback_answer_length": 50,
    "first_sentence_length": 200,
    "min_valid_answer_length": 100,
    "max_regex_scan_length": 500,
    "multiple_choice_answers": "ABCD",
    "json_indent": 2
  },
  
  "api": {
    "default_temperature": 0.0,
    "default_seed": 42,
    "max_tokens": 2048,
    "timeout": 120,
    "max_retries": 3,
    "error_text_preview_length": 200,
    "success_status_code": 200,
    "rate_limit_status_code": 429,
    "backoff_base": 2,
    "backoff_random_max": 1.0,
    "context_window_limit": 128000,
    "context_window_safety_margin": 0.1,
    "image_token_estimate": 1000
  },
  
  "http_client": {
    "timeout": 300.0,
    "connect_timeout": 10.0,
    "max_connections": 50,
    "max_keepalive_connections": 20,
    "http2": true
  },
  
  "task_processing": {
    "initial_task_counter": 1,
    "hybrid_type_threshold": 1,
    "complexity_type_threshold_simple": 1,
    "complexity_type_threshold_moderate": 2,
    "dynamic_refinement": {
      "enabled": true,
      "max_refinement_steps": 2,
      "refinement_temperature": 0.1,
      "task_id_suffix": "_recovery",
      "action_values": {
        "retry": "retry",
        "skip": "skip"
      },
      "message_templates": {
        "attempt_1": "Attempt 1:",
        "attempt_2": "Attempt 2 (Refined):"
      },
      "trigger_keywords": ["not found", "cannot see", "unclear", "no evidence", "not present", "not detected", "unable to detect", "no instances"],
      "critical_task_types": ["visual_detection", "counting"]
    }
  },
  
  "caching": {
    "lru_cache_maxsize": 16
  },
  
  "output": {
    "version": "1.2-optimized",
    "error_messages": {
      "synthesis_failed": "Synthesis Failed",
      "unknown": "Unknown",
      "unable_to_determine": "Unable to determine"
    },
    "reasoning_types": {
      "direct": "direct",
      "cisc": "CISC_Weighted_Voting",
      "failure": "failure"
    }
  },
  
  "number_to_text_mapping": {
    "zero": 0,
    "one": 1,
    "two": 2,
    "three": 3,
    "four": 4,
    "five": 5,
    "six": 6,
    "seven": 7,
    "eight": 8,
    "nine": 9,
    "ten": 10,
    "eleven": 11,
    "twelve": 12,
    "dozen": 12
  },
  
  "parsing": {
    "json_extraction": {
      "code_block_pattern": "```(?:json)?\\s*(\\{[\\s\\S]*?\\})\\s*```",
      "box_marker_pattern": "<\\|begin_of_box\\|>\\s*(\\{[\\s\\S]*?\\})\\s*<\\|end_of_box\\|>",
      "json_object_pattern": "^\\{.*\\}$"
    },
    "stage_expectations": {
      "reasoning": ["final_answer", "confidence"],
      "refinement": ["action", "new_task"],
      "decomposition": ["question_type", "strategy", "visual_risks"]
    },
    "regex_fallback": {
      "question_type": [
        "\"question_type\"\\s*:\\s*\"([^\"]*)\"",
        "question_type\\s*:\\s*['\"]([^'\"]*)['\"]"
      ],
      "complexity": [
        "\"complexity\"\\s*:\\s*\"([^\"]*)\"",
        "complexity\\s*:\\s*['\"]([^'\"]*)['\"]"
      ],
      "strategy": [
        "\"strategy\"\\s*:\\s*\"([^\"]*)\"",
        "strategy\\s*:\\s*['\"]([^'\"]*)['\"]"
      ],
      "confidence": [
        "\"confidence\"\\s*:\\s*([0-9.]+)",
        "confidence\\s*:\\s*([0-9.]+)"
      ],
      "final_answer": [
        "\"final_answer\"\\s*:\\s*\"([^\"]*)\"",
        "final_answer\\s*:\\s*['\"]([^'\"]*)['\"]",
        "\"final_answer\"\\s*:\\s*([A-Z]\\.?[^,\\n]*)"
      ]
    },
    "key_value_extraction": {
      "kv_pair_pattern": "\"([^\\\"]+)\":\\s*\"((?:[^\"\\\\]|\\\\.)*?)\""
    },
    "answer_extraction": {
      "patterns": [
        "(?:the\\s+)?(?:final\\s+)?answer\\s+is[:\\s]+(.+?)(?:\\.|$)",
        "final\\s+answer[:\\-\\s]+(.+?)(?:\\.|$)"
      ]
    },
    "number_extraction": {
      "digit_pattern": "\\d+"
    }
  }
}
