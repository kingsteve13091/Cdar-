{
  "complexity_levels": ["simple", "moderate", "complex"],
  "rules": {
    "simple": {
      "description": "Single type, direct perceptual",
      "conditions": [
        "single question type",
        "direct visual observation",
        "no complex relationships"
      ],
      "examples": ["yes_no", "simple description", "basic attribute"]
    },
    "moderate": {
      "description": "1-2 types or one simple relation",
      "conditions": [
        "1-2 question types",
        "basic relationships",
        "simple reasoning required"
      ],
      "examples": ["counting + attribute", "spatial + object", "multiple choice"]
    },
    "complex": {
      "description": ">=2 types, relations, or multi-step synthesis",
      "conditions": [
        "multiple question types",
        "complex relationships",
        "multi-step reasoning",
        "synthesis required"
    ],
      "examples": ["counting + spatial + multiple_choice", "temporal + causal", "numerical + spatial"]
    }
  },
  "force_decomposed": [
    "counting",
    "multiple_choice",
    "spatial_relational",
    "temporal",
    "numerical_reasoning",
    "causal_logical"
  ]
}
